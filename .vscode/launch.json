{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug OrderBook (GDB)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/driver/main.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/driver",
      "environment": [],
      "externalConsole": true,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
      "preLaunchTask": "Build OrderBook (g++)",
      "setupCommands": [
        {
          "description": "Enable pretty printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}